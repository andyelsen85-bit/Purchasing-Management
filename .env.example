# Copy this file to `.env` (in the same directory as docker-compose.yml) and
# replace the value below with a strong random secret. The app refuses to
# start in production if SESSION_SECRET is shorter than 32 characters or
# matches a known placeholder.
#
# Generate one with either:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
SESSION_SECRET=replace-me-with-at-least-32-random-characters
